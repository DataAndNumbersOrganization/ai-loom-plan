{
    "name": "dan/ai-loom-planner",
    "description": "Generate context files and agent prompts from Loom video walkthroughs.",
    "keywords": ["laravel", "loom", "ai", "planning", "transcript"],
    "license": "MIT",
    "homepage": "https://github.com/DataAndNumbersOrganization/ai-loom-plan",
    "support": {
        "issues": "https://github.com/DataAndNumbersOrganization/ai-loom-plan/issues",
        "source": "https://github.com/DataAndNumbersOrganization/ai-loom-plan"
    },
    "authors": [
        {
            "name": "Dan",
            "email": "dan@beautyboss.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dan\\AiLoomPlanner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dan\\AiLoomPlanner\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dan\\AiLoomPlanner\\LoomPlannerServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
